# ===== 应用 =====
APP_ENV=dev                          # dev / prod
APP_HOST=0.0.0.0
APP_PORT=8000
APP_LOG_LEVEL=INFO

# ===== 数据库 (PostgreSQL) =====
# 本地：直接装 PG 或 docker run postgres:16
DATABASE_URL=postgresql+psycopg://skin:skin@localhost:5432/skin_care

# ===== 存储 (MVP 用本地文件系统模拟 COS) =====
STORAGE_BACKEND=local                # local / cos
STORAGE_LOCAL_DIR=./storage_local    # 本地存储根目录
STORAGE_LOCAL_BASE_URL=http://localhost:8000/files  # 本地访问前缀

# ===== AI 限流 (每用户每日) =====
AI_ANALYZE_DAILY_LIMIT=10
AI_CHAT_DAILY_LIMIT=50

# ===== AI Provider =====
# MVP 第一周用 mock；接真实模型时切到 openai_compat 并填 key
AI_PROVIDER_PRIMARY=mock             # mock / qwen / glm / minimax / doubao
AI_PROVIDER_FALLBACKS=               # 逗号分隔，如 glm,minimax

# Qwen-VL (DashScope)
QWEN_API_KEY=
QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
QWEN_MODEL=qwen-vl-max

# GLM-4V (智谱)
GLM_API_KEY=
GLM_BASE_URL=https://open.bigmodel.cn/api/paas/v4
GLM_MODEL=glm-4v-plus

# MiniMax
MINIMAX_API_KEY=
MINIMAX_BASE_URL=https://api.minimax.chat/v1
MINIMAX_MODEL=abab6.5-chat

# 豆包 / Seed-Vision
DOUBAO_API_KEY=
DOUBAO_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
DOUBAO_MODEL=doubao-vision-pro

# ===== 微信小程序 =====
WX_APPID=
WX_SECRET=
