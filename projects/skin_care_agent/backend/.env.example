# ===== 应用 =====
APP_ENV=dev                          # dev / prod
APP_HOST=0.0.0.0
APP_PORT=8000
APP_LOG_LEVEL=INFO
API_V1_PREFIX=/api/v1
# 原生 App 不受浏览器 CORS 约束；仅在需要 Web 调试时填写逗号分隔白名单
CORS_ALLOWED_ORIGINS=

# ===== 数据库 (PostgreSQL) =====
# 本地：直接装 PG 或 docker run postgres:16
DATABASE_URL=postgresql+psycopg://skin:skin@localhost:5432/skin_care

# ===== 存储 (MVP 用本地文件系统模拟 COS) =====
STORAGE_BACKEND=local                # local / cos
STORAGE_LOCAL_DIR=./storage_local    # 本地存储根目录
STORAGE_LOCAL_BASE_URL=http://localhost:8000/files  # 本地访问前缀
STORAGE_URL_SIGN_SECRET=dev-only-change-me           # 签名密钥（生产改成强随机串）
STORAGE_URL_TTL_SECONDS=900                          # 签名 URL 有效期（秒），默认 15 分钟

# ===== 上传约束 =====
UPLOAD_MAX_BYTES=8388608                              # 单文件上限 8MB
UPLOAD_ALLOWED_MIMES=image/jpeg,image/png,image/webp

# ===== AI 限流 (每用户每日) =====
AI_ANALYZE_DAILY_LIMIT=10
AI_CHAT_DAILY_LIMIT=50
AI_RATELIMIT_ENFORCE_IN_DEV=false      # dev 环境默认豁免；true 时也走限流

# ===== App 认证 =====
AUTH_ACCESS_TOKEN_TTL_SECONDS=900
AUTH_REFRESH_TOKEN_TTL_SECONDS=2592000
AUTH_REGISTRATION_ENABLED=true

# ===== 首次使用必须接受的协议版本 =====
CONSENT_TERMS_VERSION=2026-07-16
CONSENT_PRIVACY_VERSION=2026-07-16
CONSENT_HEALTH_DISCLAIMER_VERSION=2026-07-16
CONSENT_AI_PROCESSING_VERSION=2026-07-16

# ===== AI Provider =====
# MVP 第一周用 mock；接真实模型时切到 openai_compat 并填 key
AI_PROVIDER_PRIMARY=mock             # mock / qwen / glm / minimax / doubao
AI_PROVIDER_FALLBACKS=               # 逗号分隔，如 glm,minimax

# Qwen-VL (DashScope)
QWEN_API_KEY=
QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
QWEN_MODEL=qwen-vl-max

# GLM 视觉（智谱）
GLM_API_KEY=
GLM_BASE_URL=https://open.bigmodel.cn/api/paas/v4
GLM_MODEL=glm-4.6v

# MiniMax
MINIMAX_API_KEY=
MINIMAX_BASE_URL=https://api.minimaxi.com/v1
MINIMAX_MODEL=MiniMax-M3

# 豆包 / Seed-Vision
DOUBAO_API_KEY=
DOUBAO_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
DOUBAO_MODEL=doubao-vision-pro

# DeepSeek
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_MODEL=deepseek-chat

# ===== 未来可选的微信身份来源（App MVP 不使用） =====
WX_APPID=
WX_SECRET=
